# SecureDesk PAM — environment variables
# Copy this to .env and adjust for production

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=pam_user
POSTGRES_PASSWORD=pam_pass
POSTGRES_DB=pam_db
DATABASE_URL=postgresql+asyncpg://pam_user:pam_pass@postgres:5432/pam_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Vault (dev mode) ─────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root-dev-token
# NOTE: In production, use Vault Agent with AppRole auth — never a root token

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-in-production-use-32-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
